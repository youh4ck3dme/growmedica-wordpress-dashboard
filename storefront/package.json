{
  "name": "@erikbabcan/growmedica-wordpress-dashboard",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --port 5555",
    "dev:playwright": "next dev --port 5557",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "type-check": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\"",
    "test": "playwright test",
    "test:integrity": "playwright test --project=integrity",
    "test:dashboard": "NEXT_PUBLIC_DASHBOARD_URL=https://growmedica-nexus.lovable.app/admin playwright test tests/integrity/dashboard.spec.ts --project=integrity",
    "test:noor-demo": "NOOR_DEMO_TEST=1 NEXT_PUBLIC_DEFAULT_THEME=noor NEXT_PUBLIC_HIDE_THEME_SWITCHER=1 playwright test tests/integrity/noor-demo.spec.ts --project=integrity",
    "test:pwa": "yarn build && PWA_PRODUCTION_TEST=1 playwright test --project=pwa",
    "generate:category-fixture": "node scripts/generate-category-coverage-fixture.mjs",
    "setup:env": "bash scripts/setup-env.sh",
    "pull:env": "bash scripts/pull-env-from-vercel.sh",
    "vercel:ignore-noor-demo-on-main": "bash scripts/set-growmedicanextjs-ignore-noor-demo-branch.sh",
    "test:e2e": "playwright test --project=e2e-chromium --project=e2e-mobile",
    "bundles:create": "node scripts/create-shopify-bundles.mjs",
    "bundles:create:dry": "node scripts/create-shopify-bundles.mjs --dry-run",
    "inventory:fix": "node scripts/fix-shopify-inventory.mjs --dry-run",
    "inventory:fix:apply": "node scripts/fix-shopify-inventory.mjs --apply",
    "inventory:fix:dry": "node scripts/fix-shopify-inventory.mjs --dry-run",
    "vercel:site-url": "bash scripts/set-vercel-site-url.sh",
    "test:ui": "playwright test --ui",
    "woo:smoke": "bash scripts/woo-smoke-test.sh",
    "import:categories": "node scripts/import-woo-categories.mjs",
    "import:categories:dry": "node scripts/import-woo-categories.mjs --dry-run",
    "import:products": "node scripts/import-woo-products.mjs",
    "import:products:dry": "node scripts/import-woo-products.mjs --dry-run"
  },
  "dependencies": {
    "@mistralai/mistralai": "^2.2.5",
    "@serwist/next": "^9.5.11",
    "framer-motion": "^12.40.0",
    "lucide-react": "^1.17.0",
    "next": "^15.3.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "serwist": "^9.5.11",
    "zod": "^3.23.8"
  },
  "browserslist": [
    "chrome >= 111",
    "edge >= 111",
    "firefox >= 111",
    "safari >= 16.4"
  ],
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@shopify/cli": "^4.1.0",
    "@tailwindcss/postcss": "^4",
    "@types/node": "20.17.6",
    "@types/react": "19.2.17",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "^15.3.4",
    "prettier": "^3.3.3",
    "tailwindcss": "^4",
    "typescript": "5.8.2"
  }
}
