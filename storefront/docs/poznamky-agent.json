{
  "id": "growmedica-shopify-admin-onboard",
  "version": "1",
  "human_doc": "./poznamky.md",
  "entry_command": "yarn shopify:admin-onboard",
  "description": "Nasadenie Shopify Admin tokenu (shpat_) — automatizuje storefront + Vercel; Shopify Admin UI a Nexus vyžadujú človeka.",
  "prerequisites": {
    "cwd": "storefront",
    "never_commit": ["SHOPIFY_ADMIN_ACCESS_TOKEN", ".env.local"]
  },
  "steps": [
    {
      "id": "shopify_create_token",
      "title": "Vytvor a nainštaluj Admin app v Shopify",
      "automated": false,
      "blocking": true,
      "urls": {
        "shop_admin": "https://admin.shopify.com/store/growmedica",
        "develop_apps": "https://admin.shopify.com/store/growmedica/settings/apps/development",
        "apps_fallback": "https://admin.shopify.com/store/growmedica/settings/apps"
      },
      "actions": [
        "Create an app (napr. GrowMedica Nexus)",
        "Configure Admin API scopes: read_products, write_products, read_inventory, write_inventory",
        "Save → API credentials → Install app",
        "Skopíruj Admin API access token (shpat_...)"
      ],
      "alternatives": [
        {
          "if": "Develop apps nie je v menu",
          "then": "Settings → Apps → Allow custom app development → ulož → Develop apps"
        },
        {
          "if": "Nemáš Develop apps",
          "then": "Musíš byť store owner alebo mať oprávnenie Develop apps"
        }
      ],
      "agent_input": {
        "env": "SHOPIFY_ADMIN_ACCESS_TOKEN",
        "cli_flag": "--token"
      }
    },
    {
      "id": "storefront_onboard",
      "title": "Storefront: .env.local + overenie + Vercel + smoke",
      "automated": true,
      "command": "yarn shopify:admin-onboard --token \"$SHOPIFY_ADMIN_ACCESS_TOKEN\"",
      "command_no_vercel": "yarn shopify:admin-onboard --token \"$SHOPIFY_ADMIN_ACCESS_TOKEN\" --no-vercel",
      "success_when": "exit_code === 0 && report.admin_api === 'ok' && report.storefront_smoke === 'ok'",
      "on_failure": {
        "403_api_disabled": {
          "human_step": "shopify_create_token",
          "message": "Token je v env, ale Shopify vracia 403 — app nie je nainštalovaná."
        },
        "401_unauthorized": {
          "human_step": "shopify_create_token",
          "message": "Neplatný token — vygeneruj nový v Shopify Admin."
        },
        "missing_token": {
          "human_step": "shopify_create_token",
          "message": "Chýba SHOPIFY_ADMIN_ACCESS_TOKEN — použi --token alebo env."
        }
      }
    },
    {
      "id": "nexus_env",
      "title": "Nexus (Lovable): vlož rovnaký token",
      "automated": false,
      "blocking": false,
      "urls": {
        "nexus_admin": "https://growmedica-nexus.lovable.app/admin",
        "lovable": "https://lovable.dev"
      },
      "env_vars": {
        "SHOPIFY_STORE_DOMAIN": "growmedica.myshopify.com",
        "SHOPIFY_ADMIN_ACCESS_TOKEN": "<shpat_ z kroku shopify_create_token>",
        "SHOPIFY_API_VERSION": "2025-01",
        "SHOPIFY_STOREFRONT_ACCESS_TOKEN": ""
      },
      "rules": [
        "SHOPIFY_STOREFRONT_ACCESS_TOKEN nesmie byť shpat_",
        "Po uložení spusti Test pripojenia v Nexus UI ak existuje"
      ],
      "alternatives": [
        {
          "if": "Integrations v Nexus UI nevidíš",
          "then": "lovable.dev → projekt growmedica-nexus → Settings → Environment variables"
        },
        {
          "if": "Nexus je na Vercel",
          "then": "vercel.com → projekt Nexus → Settings → Environment Variables"
        }
      ]
    },
    {
      "id": "iframe_firebase",
      "title": "Ak dashboard iframe / login zlyhá",
      "automated": false,
      "blocking": false,
      "urls": {
        "firebase_auth_domains": "https://console.firebase.google.com/"
      },
      "actions": [
        "Authentication → Settings → Authorized domains",
        "Pridaj: growmedica.cz, www.growmedica.cz, growmedicanextjs.vercel.app, growmedica-nexus.lovable.app"
      ],
      "doc": "./DASHBOARD_DEPLOY.md#3-firebase-authorized-domains-manuálne-v-firebase-console"
    }
  ],
  "verification": {
    "admin_api": "node scripts/shopify-admin-onboard.mjs --verify-only",
    "storefront_catalog": "yarn shopify:smoke",
    "production_products": "curl -sS https://www.growmedica.cz/api/products | head -c 200",
    "dashboard_agent": "BASE_URL=https://www.growmedica.cz node scripts/mistral-agent-live-smoke.mjs"
  },
  "agent_protocol": [
    "Ak user pošle shpat_ token → spusti yarn shopify:admin-onboard --token <token> --json",
    "Ak 403 → vypíš human_step shopify_create_token s URL z tohto JSON; neopakuj Vercel push",
    "Nikdy necommituj token; nikdy nedávaj shpat_ do SHOPIFY_STOREFRONT_ACCESS_TOKEN",
    "Po úspechu pripomeň human_step nexus_env (Lovable — mimo tohto repa)",
    "UI komponenty nemeň (AGENTS.md freeze)"
  ]
}