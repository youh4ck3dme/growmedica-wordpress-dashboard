# ─── CMS (WordPress + WooCommerce only) ─────────────────────────────────────
# Shopify runtime removed — storefront always uses Woo REST.
# Production DB credentials: ../wordpress.local.md + ../wordpress-production.local.env (gitignored)
WORDPRESS_BASE_URL=http://localhost:8080
WOO_CONSUMER_KEY=ck_your-consumer-key-here
WOO_CONSUMER_SECRET=cs_your-consumer-secret-here
WORDPRESS_REVALIDATION_SECRET=your-wordpress-webhook-secret-min-16-chars
# Optional dedicated cart HMAC (falls back to WORDPRESS_REVALIDATION_SECRET)
# CART_SIGNING_SECRET=your-cart-signing-secret-min-16-chars
# WOO_MOCK_MODE=1  # offline WooCommerce fixture data (Playwright / local dev)

# ─── Public URLs ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://growmedica.cz
NEXT_PUBLIC_DEFAULT_LOCALE=cs

# Soft-launch SEO gate (default ON when unset = noindex whole shop).
# Set to 0 when ready for Google indexing: SITE_NOINDEX=0
SITE_NOINDEX=1
# NEXT_PUBLIC_SITE_NOINDEX=1  # optional mirror for edge middleware

# /dashboard — native admin (agentic mode, no Nexus iframe)
# agentic | iframe | hybrid (default: agentic)
NEXT_PUBLIC_DASHBOARD_MODE=agentic
# Server-only secret for /api/dashboard/* (min 16 chars)
DASHBOARD_AGENT_SECRET=local-dashboard-agent-secret-min-16-chars
# Live Shopify Admin writes from dashboard (production only)
# DASHBOARD_ALLOW_LIVE_WRITES=1

# Legacy Shopify public names (optional during migration)
# NEXT_PUBLIC_SHOPIFY_STORE_DOMAIN=your-store.myshopify.com
# NEXT_PUBLIC_SHOPIFY_STOREFRONT_ACCESS_TOKEN=your-storefront-access-token

# ─── Mistral AI (server-only) ─────────────────────────────────────────────────
MISTRAL_API_KEY=
MISTRAL_API_KEY_BACKUP=
MISTRAL_MODEL=mistral-large-latest
# MISTRAL_MOCK_MODE=1

# ─── Optional ─────────────────────────────────────────────────────────────────
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# NOOR demo theme lock
# NEXT_PUBLIC_DEFAULT_THEME=noor
# NEXT_PUBLIC_HIDE_THEME_SWITCHER=1
