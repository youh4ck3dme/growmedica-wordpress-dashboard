# ─── CMS Provider ───────────────────────────────────────────────────────────
# shopify (default) | wordpress
CMS_PROVIDER=shopify

# ─── WordPress / WooCommerce (required when CMS_PROVIDER=wordpress) ───────────
WORDPRESS_BASE_URL=http://localhost:8080
WOO_CONSUMER_KEY=ck_your-consumer-key-here
WOO_CONSUMER_SECRET=cs_your-consumer-secret-here
WORDPRESS_REVALIDATION_SECRET=your-wordpress-webhook-secret-min-16-chars
# WOO_MOCK_MODE=1  # offline WooCommerce fixture data (Playwright / local dev)

# ─── Shopify (required when CMS_PROVIDER=shopify) ─────────────────────────────
# Canonical: growmedica.myshopify.com
SHOPIFY_STORE_DOMAIN=growmedica.myshopify.com
SHOPIFY_STOREFRONT_ACCESS_TOKEN=your-storefront-access-token-here
# SHOPIFY_STOREFRONT_TOKENLESS=1  # growmedica.myshopify.com — tokenless Storefront API (no token above)
SHOPIFY_REVALIDATION_SECRET=your-shopify-webhook-secret-min-16-chars
SHOPIFY_API_VERSION=2025-01
# SHOPIFY_MOCK_MODE=1  # offline Shopify fixture data (Playwright / local dev)

# Shopify Web Bot Auth — HTTP Message Signatures (server-only, optional)
SHOPIFY_WEB_BOT_AUTH_NAME=your-web-bot-auth-name
SHOPIFY_WEB_BOT_AUTH_DOMAIN=growmedica.myshopify.com
SHOPIFY_WEB_BOT_AUTH_SIGNATURE=sig1=:base64-signature-here:
SHOPIFY_WEB_BOT_AUTH_SIGNATURE_INPUT=sig1=("@authority" "signature-agent");keyid="...";nonce="...";tag="web-bot-auth";created=0;expires=0
SHOPIFY_WEB_BOT_AUTH_SIGNATURE_AGENT=https://shopify.com
SHOPIFY_WEB_BOT_AUTH_EXPIRES=YYYY-MM-DD

# ─── Public URLs ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://growmedica.cz
NEXT_PUBLIC_DEFAULT_LOCALE=sk

# /dashboard iframe — Lovable Nexus admin (WordPress CMS je na cms.growmedica.cz/wp-admin)
NEXT_PUBLIC_DASHBOARD_URL=https://growmedica-nexus.lovable.app/admin
# agentic | iframe | hybrid (default: hybrid)
NEXT_PUBLIC_DASHBOARD_MODE=hybrid
# Server-only secret for /api/dashboard/* (min 16 chars)
DASHBOARD_AGENT_SECRET=local-dashboard-agent-secret-min-16-chars
# Legacy fallback (deprecated):
# NEXT_PUBLIC_DASHBOARD_URL=https://growmedica-nexus.lovable.app/admin

# Legacy Shopify public names (optional during migration)
# NEXT_PUBLIC_SHOPIFY_STORE_DOMAIN=your-store.myshopify.com
# NEXT_PUBLIC_SHOPIFY_STOREFRONT_ACCESS_TOKEN=your-storefront-access-token

# ─── Mistral AI (server-only) ─────────────────────────────────────────────────
MISTRAL_API_KEY=
MISTRAL_API_KEY_BACKUP=
MISTRAL_MODEL=mistral-large-latest
# MISTRAL_MOCK_MODE=1

# ─── Optional ─────────────────────────────────────────────────────────────────
# SHOPIFY_ADMIN_ACCESS_TOKEN=shpat_...  # local scripts only
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# NOOR demo theme lock
# NEXT_PUBLIC_DEFAULT_THEME=noor
# NEXT_PUBLIC_HIDE_THEME_SWITCHER=1
